# ============================================================
# SolarSync Power Manager — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# The .env file is never committed to version control.

# ---- Internal API Security ----
# Shared secret between Laravel and FastAPI — generate with: openssl rand -hex 32
INTERNAL_API_KEY=CHANGE_ME

# ---- Application ----
APP_NAME="SolarSync"
APP_ENV=production
APP_DEBUG=false
# Used by Laravel for session encryption etc. — generate with: openssl rand -hex 32
APP_KEY=base64:CHANGE_ME

# ---- Database ----
# Path inside the container — mapped to a Docker volume
DB_DATABASE=/data/solarsync.sqlite

# ---- Laravel Auth ----
# Single-household admin credentials — used by the web login page.
# SOLARSYNC_USERNAME is also used as the display name.
SOLARSYNC_USERNAME=admin
SOLARSYNC_PASSWORD=CHANGE_ME

# ---- KlikAanKlikUit / ICS2000 ----
KAKU_MAC_ADDRESS=00:00:00:00:00:00
KAKU_EMAIL=your@email.nl
KAKU_PASSWORD=your_password

# ---- SolarEdge API (optional) ----
SOLAREDGE_API_KEY=
SOLAREDGE_SITE_ID=

# ---- MQTT / Zigbee2MQTT (optional) ----
MQTT_HOST=mosquitto
MQTT_PORT=1883
# MQTT_USERNAME and MQTT_PASSWORD are required — anonymous access is disabled.
# After setting these values, generate the Mosquitto password file by running:
#   docker run --rm -v $(pwd)/mosquitto:/mosquitto eclipse-mosquitto:2 \
#     mosquitto_passwd -c /mosquitto/config/passwd <MQTT_USERNAME>
# Or, if mosquitto-clients is installed on the host:
#   mosquitto_passwd -c solarsync/mosquitto/passwd <MQTT_USERNAME>
MQTT_USERNAME=CHANGE_ME
MQTT_PASSWORD=CHANGE_ME

# ---- Solar Engine ----
# How often (in seconds) to check solar surplus and update appliances
POLL_INTERVAL_SECONDS=300

# ---- CORS ----
# Comma-separated list of allowed origins for the FastAPI backend.
# Set this to your actual hostname(s) — wildcard "*" is not permitted in production.
# Example: ALLOWED_ORIGINS=https://solarsync.local,https://192.168.1.100
ALLOWED_ORIGINS=https://localhost

# ---- Docker image (for Watchtower auto-updates) ----
GHCR_IMAGE=ghcr.io/CHANGE_ME/solarsync
IMAGE_TAG=latest
