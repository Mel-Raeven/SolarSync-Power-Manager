# ============================================================
# SolarSync Power Manager — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# The .env file is never committed to version control.
#
# NOTE: Most configuration (energy source, hub credentials, appliances)
# is done through the web interface after first boot — not here.
# The variables below are infrastructure-level settings.

# ---- Web Login ----
# Set your desired username and password for the web interface.
# The install script will prompt for these — you rarely need to set them here.
SOLARSYNC_USERNAME=
SOLARSYNC_PASSWORD=

# ---- Internal Security ----
# Auto-generated by the install script — do not change unless you know what you're doing.
INTERNAL_API_KEY=

# ---- Laravel Application Key ----
# Auto-generated by the install script — do not set manually.
APP_KEY=

# ---- Database ----
DB_DATABASE=/data/solarsync.sqlite

# ---- Solar Engine ----
# How often (in seconds) to check solar surplus and update appliances.
POLL_INTERVAL_SECONDS=300

# ---- CORS ----
# The hostname(s) you use to access the dashboard.
# Defaults to localhost — change this if you access SolarSync by hostname.
# Example: ALLOWED_ORIGINS=https://solarsync.local,https://192.168.1.100
ALLOWED_ORIGINS=https://localhost

# ---- Docker image (for Watchtower auto-updates) ----
GHCR_IMAGE=ghcr.io/CHANGE_ME/solarsync
IMAGE_TAG=latest

# ---- MQTT (internal — auto-generated by install script) ----
# These are used only between Docker services. You do not need to manage them manually.
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
